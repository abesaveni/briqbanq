# ─── Database ────────────────────────────────────────────────────────────────
# Docker: replace 'localhost' with 'db' (the service name)
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@localhost:5432/brickbanq
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:CHANGE_ME@localhost:5432/brickbanq

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker: replace 'localhost' with 'redis'
REDIS_URL=redis://localhost:6379/0

# ─── JWT — MUST be changed before production ──────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_64_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=240
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=BrickBanq
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ─── Email (Gmail SMTP — use an App Password, not your account password) ──────
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False

# ─── AWS (optional — for S3 document storage) ─────────────────────────────────
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=brickbanq-documents

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=10/minute

# ─── Square Payments ──────────────────────────────────────────────────────────
SQUARE_ACCESS_TOKEN=REPLACE_ME
SQUARE_LOCATION_ID=REPLACE_ME
SQUARE_ENVIRONMENT=sandbox
